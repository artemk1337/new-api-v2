FROM golang:1.26.1-alpine@sha256:2389ebfa5b7f43eeafbd6be0c3700cc46690ef842ad962f6c5bd6be49ed82039 AS builder

WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -ldflags "-s -w" -o new-api-updater ./cmd/new-api-updater

FROM docker:28-cli

COPY --from=builder /build/new-api-updater /usr/local/bin/new-api-updater
EXPOSE 18090
ENTRYPOINT ["new-api-updater"]
